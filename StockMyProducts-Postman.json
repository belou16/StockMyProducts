    {
      "name": "Stock Management",
      "description": "Stock movements, history, and inventory management",
      "item": [
        {
          "name": "Stock In (Entry)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 201) {",
                  "    var jsonData = pm.response.json();",
                  "    console.log('✅ Stock In recorded: ' + jsonData.data.product.name + ' +' + jsonData.data.movement.quantity + ' units');",
                  "    console.log('   Previous stock: ' + jsonData.data.product.stockBefore);",
                  "    console.log('   New stock: ' + jsonData.data.product.stockAfter);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{jwt_token}}",
                  "type": "string"
                }
              ]
            },
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\"product\": \"{{product_id}}\", \"quantity\": 20, \"reason\": \"purchase\", \"details\": \"Achat auprès du fournisseur ABC\", \"reference\": \"BON-ACHAT-2024-001\"}"
            },
            "url": {
              "raw": "{{base_url}}/stock/in",
              "host": ["{{base_url}}"],
              "path": ["stock", "in"]
            }
          }
        },
        {
          "name": "Stock Out (Exit)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 201) {",
                  "    var jsonData = pm.response.json();",
                  "    console.log('✅ Stock Out recorded: ' + jsonData.data.product.name + ' -' + jsonData.data.movement.quantity + ' units');",
                  "    console.log('   Previous stock: ' + jsonData.data.product.stockBefore);",
                  "    console.log('   New stock: ' + jsonData.data.product.stockAfter);",
                  "} else if (pm.response.code === 400) {",
                  "    var jsonData = pm.response.json();",
                  "    console.log('⚠️  Stock out prevented: ' + jsonData.message);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{jwt_token}}",
                  "type": "string"
                }
              ]
            },
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\"product\": \"{{product_id}}\", \"quantity\": 5, \"reason\": \"sale\", \"details\": \"Vente au client XYZ\", \"reference\": \"VENTE-2024-001\"}"
            },
            "url": {
              "raw": "{{base_url}}/stock/out",
              "host": ["{{base_url}}"],
              "path": ["stock", "out"]
            }
          }
        },
        {
          "name": "Stock Out - NEGATIVE PREVENTION TEST",
          "description": "This request should FAIL with 400 error (Insufficient Stock). Tests negative stock prevention.",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 400) {",
                  "    var jsonData = pm.response.json();",
                  "    console.log('✅ TEST PASSED: Negative stock prevention working!');",
                  "    console.log('   Error: ' + jsonData.message);",
                  "    console.log('   Available stock: ' + jsonData.availableStock);",
                  "    console.log('   Requested: ' + jsonData.requestedQuantity);",
                  "} else {",
                  "    console.log('❌ TEST FAILED: Should have been prevented!');",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{jwt_token}}",
                  "type": "string"
                }
              ]
            },
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\"product\": \"{{product_id}}\", \"quantity\": 10000, \"reason\": \"sale\", \"details\": \"Test: Try to sell more than stock\"}"
            },
            "url": {
              "raw": "{{base_url}}/stock/out",
              "host": ["{{base_url}}"],
              "path": ["stock", "out"]
            }
          }
        },
